# Copy to .env.local and fill in the values.

# --- Supabase (auth) ---
# Project URL and anon/public key — both are browser-safe.
# Find them in Supabase dashboard → Project Settings → API.
# Also add https://<your-domain>/auth/callback to Supabase → Authentication → URL Configuration → Redirect URLs.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Backend URL (only needed in production) ---
# Leave unset in local dev — Vite's proxy forwards /api/* to the backend.
# In production set this to your Render/backend URL, e.g.:
# VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=
