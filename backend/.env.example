# Copy to .env (or set these in your host's environment).
# Leave everything unset to use local Ollama (the free, offline default).

# --- Choose your AI engine ---
# "auto" (default): prefers Groq, then Gemini, then local Ollama, based on
#   which API key is set below.
# "ollama": always local.  "groq" / "gemini": always that cloud provider.
AI_PROVIDER=auto

# --- Local Ollama (default) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Groq (free cloud API; fast; get a key at https://console.groq.com/keys) ---
# Recommended cloud option. Makes the app independent of your computer.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (alternative free cloud API; https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Public deployment (only needed when hosting) ---
# Comma-separated frontend URLs allowed to call this backend (CORS).
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Supabase (shareable read-only reports) ---
# Create a project at https://supabase.com, then run this SQL in the editor:
#
#   create table reports (
#     id         text primary key,
#     title      text not null,
#     content    text not null,
#     created_at timestamptz default now()
#   );
#
# Get URL + anon key from Project Settings → API.
SUPABASE_URL=
SUPABASE_KEY=
